    "siwe": "^3.0.0",
    "viem": "^2.21.54"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
