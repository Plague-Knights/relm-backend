# Local dev defaults. Never commit a populated .env — the signer key
# here has permission to mint RELM tokens.

DATABASE_URL="file:./dev.db"

PORT=3000

# Shared secret the Luanti mod sends as X-Relm-Secret on every ingest.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
RELM_BACKEND_SECRET=changeme

# Soneium Minato (testnet) — flip to soneium mainnet once the economy
# is playtested and the contract has been re-deployed on prod.
CHAIN=minato
MINATO_RPC_URL=https://rpc.minato.soneium.org

# EOA that owns the RelmToken contract's minter role. Stays offline in
# dev; production will route through a laptop-only signer like
# ink-bird's split-settlement pattern.
SIGNER_PRIVATE_KEY=

# Deployed RelmToken address on Minato (fill in after `forge script`).
RELM_TOKEN_ADDRESS=

# Public URL of this server — used in wallet-link challenge payloads
# so the player's browser flow lands back here.
PUBLIC_BASE_URL=http://localhost:3000

# Daily reward cap (in bps) per player. 10000 bps = 1 RELM.
# Default 30000 = 3 RELM/day. Lower this to ratchet supply growth
# without redeploying contracts.
RELM_DAILY_CAP_BPS=30000

# === LAND / SOLANA PAYMENT RAIL ===
# Land plots are bought with SOL on Solana mainnet — completely
# decoupled from RELM tokenomics so the game economy isn't dragged
# around by SOL price.

# RPC endpoint we poll for inbound payments. Default works but you
# should bring your own (Helius, QuickNode, Triton — anything with
# higher rate limits than the public mainnet endpoint).
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Solana wallet that receives land payments. ALL plot sale revenue
# goes here directly — no contract, no escrow, no bridge. Use a
# hardware wallet address in production.
TREASURY_SOL_ADDRESS=

# Land tier pricing in SOL (override the in-code defaults so we can
# adjust as SOL/USD moves without redeploying).
LAND_TIER1_SOL=0.25
LAND_TIER2_SOL=1.0
LAND_TIER3_SOL=3.0
