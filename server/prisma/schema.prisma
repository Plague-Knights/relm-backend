// Prisma schema for the Relm backend.
// SQLite locally; swap to Postgres when we deploy to Railway.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// A verified link between a Luanti player account and a Soneium
// wallet address. One-way lookup both directions:
// - relm_wallet /wallet → address for a given player
// - deduplicate addresses so a wallet can't be bound to two players
model PlayerWallet {
  id                String   @id @default(cuid())
  player            String   @unique
  address           String   @unique
  // Which Fighter the player is wearing in-game right now. Null →
  // default Luanti skin. The Lua mod reads this on join + on
  // /myfighter <id> commands to swap the active skin.
  activeFighterId   String?
  // Pickaxe upgrade tier — sink layer. 0=wood (free), 1=stone (100 RELM),
  // 2=steel (500), 3=diamond (2500), 4=ink/legendary (10000). Each step
  // splits 50% burn / 50% treasury.
  pickaxeTier       Int      @default(0)
  linkedAt          DateTime @default(now())
}

// Short-lived challenge issued when a player runs /wallet-link in game.
// The browser flow signs this nonce with the player's wallet to prove
// ownership before PlayerWallet is written.
model WalletChallenge {
  id        String   @id @default(cuid())
  player    String
  nonce     String   @unique
  expiresAt DateTime
  consumed  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([player])
}

// Per-player energy meter. Scoring rewards only fire while a player
// has energy > 0; each scored event decrements 1. Energy regenerates
// at REGEN_PER_MIN per minute up to MAX_ENERGY (constants live in
// server/src/lib/energy.ts so the curve is in one place).
//
// `lastRegenAt` lets the regen worker compute the eligible regen
// without us holding a per-player timer.
model PlayerEnergy {
  player      String   @id
  current     Int      @default(100)
  lastRegenAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Refill receipts so we don't double-credit a chain event if the
// watcher restarts mid-batch.
model EnergyRefill {
  id        String   @id @default(cuid())
  player    String
  address   String
  amount    Int
  txHash    String   @unique
  createdAt DateTime @default(now())

  @@index([player])
}

// Reward events batched by the Lua mod. Scored asynchronously and
// converted into on-chain mints. `pending` until the scorer picks it
// up; `scored` after scoring; `minted` once the tx lands.
model RewardEvent {
  id        String   @id @default(cuid())
  player    String
  address   String
  kind      String   // dignode | placenode | hp_change | death
  payload   String   // JSON blob
  scoreBps  Int?     // points (bps = 1/10000 of a token)
  mintedAt  DateTime?
  txHash    String?
  createdAt DateTime @default(now())

  @@index([address, createdAt])
  @@index([mintedAt])
}

// Per-player daily earnings counter. Tracks bps awarded today (UTC),
// hard-capped at RELM_DAILY_CAP_BPS. Replaces the older PlayerEnergy
// gating model — see lib/dailyCap.ts.
model PlayerDaily {
  player    String
  day       String   // YYYY-MM-DD UTC
  bpsEarned Int      @default(0)
  updatedAt DateTime @updatedAt

  @@id([player, day])
  @@index([day])
}

// Land registry. Plots are bought with SOL on Solana mainnet (the
// game economy is RELM-on-Soneium, but land is "real" / fiat-equivalent
// so it stays uncorrelated to RELM token price swings).
//
// Three tiers — Plot / Region / Territory — defined in lib/landTiers.ts.
// Coordinates are world-space (x, z) at the bottom-left corner; the
// plot covers (x..x+size, z..z+size) for all y values.
model LandPlot {
  id           String   @id @default(cuid())
  x            Int
  z            Int
  tier         Int      // 1 = Plot, 2 = Region, 3 = Territory
  size         Int      // edge length in blocks; derived from tier
  status       String   @default("available") // available | reserved | owned
  ownerPlayer  String?  // Luanti player name (links via PlayerWallet)
  ownerSolAddr String?  // Solana wallet that paid
  txSignature  String?  // Solana tx that closed the sale
  claimedAt    DateTime?
  // Custom display name (Tier-3 territories can name their region)
  label        String?
  createdAt    DateTime @default(now())

  @@unique([x, z, tier])
  @@index([ownerPlayer])
  @@index([status])
}

// Pending purchase intent. The site mints one of these when a player
// picks a plot; the player has `expiresAt` minutes to send `priceSol`
// to TREASURY_SOL_ADDRESS with `memo` in the tx memo. The watcher
// matches and converts to a LandPlot.status = "owned".
model LandPaymentIntent {
  id           String   @id @default(cuid())
  plotId       String   @unique
  player       String   // Luanti player name (immutable on this intent)
  solAddr      String?  // wallet they intend to pay from (optional, advisory)
  priceSol     String   // decimal as string for precision
  memo         String   @unique // randomized; "relm-land-<8 hex>"
  expiresAt    DateTime
  matchedTx    String?  // tx signature that fulfilled this intent
  fulfilledAt  DateTime?
  createdAt    DateTime @default(now())

  @@index([player])
  @@index([expiresAt])
}

// Observed Solana txs to the treasury wallet. Watcher polls and writes
// these idempotently (tx signature is unique). Lets us replay matching
// against intents if a watcher restart misses a tick.
model SolanaPayment {
  id          String   @id @default(cuid())
  signature   String   @unique
  fromAddr    String
  amountSol   String   // decimal string
  memo        String?
  matchedPlot String?
  observedAt  DateTime @default(now())

  @@index([memo])
  @@index([fromAddr])
}

// Internal "game wallet" balance per player. Used by the Arena (and
// any future mini-game). All values in bps; 10,000 bps = 1 RELM.
// Mints from the scorer credit this balance; on-chain withdrawals
// debit it. Bets / payouts move it around without touching the chain.
model PlayerBalance {
  player     String   @id
  balanceBps Int      @default(0)
  updatedAt  DateTime @updatedAt
}

// Arena round — 4 NPC fighters per round, pari-mutuel betting in
// RELM (off-chain balance). Outcomes are deterministic: server
// commits H(seed) when the round opens, reveals the seed when the
// betting window closes, the sim runs purely from (fighter stats,
// seed). Anyone can re-derive the outcome offline.
model ArenaRound {
  id              String      @id @default(cuid())
  status          String      // OPEN | LOCKED | SETTLED
  seedCommit      String      // sha256(seed) hex
  seedReveal      String?     // hex seed, populated at LOCKED
  fighters        Json        // [{ id, name, power, speed, luck }]
  winnerIdx       Int?
  totalPoolBps    Int         @default(0)
  houseBps        Int         @default(0)
  bettingClosesAt DateTime
  settledAt       DateTime?
  createdAt       DateTime    @default(now())

  bets            ArenaBet[]

  @@index([status, bettingClosesAt])
}

model ArenaBet {
  id         String     @id @default(cuid())
  roundId    String
  round      ArenaRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  player     String
  fighterIdx Int        // 0..3
  amountBps  Int
  payoutBps  Int        @default(0)
  settled    Boolean    @default(false)
  createdAt  DateTime   @default(now())

  @@unique([roundId, player, fighterIdx])
  @@index([roundId])
  @@index([player])
}

// Bot-controlled "collect the objective" match. A round of this is
// a 5-minute window where 4-8 fighters compete to grab as many
// objectives as possible. Each fighter is driven by an external
// script (the bot) which polls /state and posts /intent. Server is
// authoritative on positions + scoring so cheaters can't lie about
// pickups. Settled outcomes feed the same pari-mutuel betting model
// the Arena already uses.
model BotMatch {
  id              String       @id @default(cuid())
  status          String       // OPEN | RUNNING | SETTLED | CANCELLED
  // Square arena bounds in nodes (e.g. 16 = 16x16 area centered at origin).
  arenaSize       Int          @default(16)
  // RNG seed for objective layout. Committed up front, revealed at
  // settle so bots can't precompute and observers can verify.
  seedCommit      String
  seedReveal      String?
  startsAt        DateTime
  endsAt          DateTime
  bettingClosesAt DateTime
  settledAt       DateTime?
  // Risk-to-earn: every entry pays this fee (RELM bps) to play. The
  // pool funds payouts to top finishers + the house cut. Losers
  // forfeit their fee — that's the gambling on the owner side. The
  // pari-mutuel `bets` table is a separate gambling layer for
  // non-owner spectators.
  entryFeeBps     Int          @default(10000)  // 1 RELM by default
  prizePoolBps    Int          @default(0)      // sum of paid-in fees
  // Top-N split of the prize pool after house cut. Stored as JSON
  // weights so different match types can pay 1st/2nd/3rd vs winner-
  // takes-all. e.g. [60, 25, 10] → 1st 60%, 2nd 25%, 3rd 10%, rest house.
  payoutSplit     Json         @default("[60,25,10]")
  // Total RELM pool from spectator bets.
  totalPoolBps    Int          @default(0)
  houseBps        Int          @default(0)
  winnerEntryId   String?
  createdAt       DateTime     @default(now())

  entries         BotMatchEntry[]
  bets            BotMatchBet[]
  objectives      BotMatchObjective[]

  @@index([status, startsAt])
}

// One entry per fighter in a match. Each fighter has its own bot
// (controller script) that owns the intent stream for that entry.
model BotMatchEntry {
  id          String     @id @default(cuid())
  matchId     String
  match       BotMatch   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  fighterId   String     // FK to Fighter. Stays a string, not relation,
                         // so deletion of an old fighter doesn't cascade
                         // through historical matches.
  // Live state — updated each tick by the match runtime.
  posX        Float      @default(0)
  posZ        Float      @default(0)
  yaw         Float      @default(0)
  hp          Int        @default(100)
  score       Int        @default(0) // objectives collected
  // Intent the bot most recently submitted. Server applies it on the
  // next tick; clears after applying.
  intentMoveX Float?
  intentMoveZ Float?
  intentAction String?   // "collect" | "idle" | future verbs
  intentAt    DateTime?
  // Auth — bots send this token in the Authorization header so anyone
  // can't post intents on someone else's behalf.
  intentToken String     @unique
  // Entry fee accounting. Set when the entry is created. Returned
  // (in part) via prize-pool split if this entry finishes in the
  // payout zone; otherwise forfeited to the pool.
  entryFeeBps Int        @default(0)
  // Final placement (1 = 1st, 2 = 2nd, ...). Filled at settle.
  placement   Int?
  payoutBps   Int        @default(0)

  @@index([matchId])
  @@index([fighterId])
}

// One row per objective in the match. status flips to "collected" the
// instant a bot enters its tile — server-authoritative.
model BotMatchObjective {
  id          String     @id @default(cuid())
  matchId     String
  match       BotMatch   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  posX        Float
  posZ        Float
  value       Int        @default(1) // points (some objectives could be worth more)
  status      String     @default("active") // active | collected
  collectedBy String?    // BotMatchEntry id
  collectedAt DateTime?

  @@index([matchId, status])
}

model BotMatchBet {
  id         String     @id @default(cuid())
  matchId    String
  match      BotMatch   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player     String     // Luanti player name placing the bet
  entryId    String     // BotMatchEntry they're betting on
  amountBps  Int
  payoutBps  Int        @default(0)
  settled    Boolean    @default(false)
  createdAt  DateTime   @default(now())

  @@unique([matchId, player, entryId])
  @@index([matchId])
  @@index([player])
}

// Permanent fighter identity. Pass 1: backend-created, stats baked at
// creation. Pass 2: backed by a Solana NFT — `mint` becomes the SPL
// mint address, ownerSol is read from chain ownership, stats live on
// the on-chain metadata. Backend stays the single source of truth for
// win/loss/race count to keep the arena worker fast.
// Token economy ledger. Every RELM mint/burn/treasury movement gets a
// row so we can compute circulating supply, daily burn rate, and the
// mint/burn ratio. Burn rows mean RELM is permanently destroyed
// (deflationary). Treasury rows mean RELM is locked in the house pool
// (used for prize pools, tournament rewards, governance funding).
// /go/<key> click attribution. Each redirect logs a row so we can A/B
// which content niches + which channels actually convert.
model RefClick {
  id        String   @id @default(cuid())
  key       String                              // e.g. "gambulls"
  niche     String?                             // optional: gambling, sports, etc
  source    String?                             // ig, tiktok, telegram, bio, ...
  referer   String?
  ua        String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([key, createdAt])
  @@index([niche, createdAt])
}

model EconLedger {
  id        String   @id @default(cuid())
  // mint | burn | treasury | shop_buy | land_tax | tournament_fee | refund
  kind      String
  amountBps Int
  // Optional player or address attribution.
  player    String?
  address   String?
  // Free-form context (e.g. {"typeId":3,"reason":"shop_buy"} for shop).
  meta      String?
  createdAt DateTime @default(now())

  @@index([kind, createdAt])
  @@index([player])
}

model Fighter {
  id          String   @id @default(cuid())
  // SPL mint address once on-chain. Null until Pass 2.
  mint        String?  @unique
  name        String
  power       Int      // 25-95
  speed       Int      // 25-95
  luck        Int      // 25-95
  ownerSol    String?  // Solana wallet that owns the NFT
  ownerPlayer String?  // Luanti player name (denormalized, optional)
  // Lifetime record. Updated on settle.
  wins        Int      @default(0)
  losses      Int      @default(0)
  races       Int      @default(0)
  retired     Boolean  @default(false)
  // Whether the fighter is currently entered into the active pool.
  // Owners can withdraw to "rest" their fighter; only entered ones
  // get drafted into rounds.
  entered     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([entered, retired])
  @@index([ownerSol])
}
