# Public-facing env (NEXT_PUBLIC_* is shipped to the browser).

# WalletConnect project id — create one at https://cloud.reown.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Where the Express backend lives. Defaults to the same origin in prod;
# set to http://localhost:3000 in local dev when running the server
# and the link app on different ports.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
